  "studentList": {
    "virtualized": true,
    "nameCells": {
      "candidates": [
        {
          "selector": ".cl-grid[role='grid'] .cl-grid-row[role='row'] .cl-grid-cell[role='gridcell'][aria-label*='성명']"
        },
        {
          "selector": ".cl-grid-row[role='row'] .cl-grid-cell[aria-label*='성명']"
        }
      ],
      "extractSelector": ".cl-grid[role='grid'] .cl-grid-row[role='row'] .cl-grid-cell[role='gridcell'][aria-label*='성명']",
      "extractor": "ariaLabelRegex",
      "ariaLabelPattern": "성명\\s+(?<name>[^\\s]+)"
    }
  },
  "attendanceRows": {
    "rowCandidates": [
      {
        "selector": ".cl-grid-row[role='row']:has(.cl-grid-cell[role='gridcell'][aria-label*='성명 ${name}'])"
      },
      {
        "selector": ".cl-grid-row[role='row']:has-text('${name}')"
      },
      {
        "text": "${name}"
      }
    ],
    "fields": {
      "status": {
        "action": "clickCellByDay",
        "selectorTemplate": ".cl-grid-cell[role='gridcell'][aria-label*='${day}일'][aria-label*='편집창']",
        "force": true,
        "fallbackCandidates": [
          {
            "selector": ".cl-grid-cell[role='gridcell'][title*='${year}.${monthPadded}.${day}.'][title*='${name}']",
            "force": true
          }
        ]
      }
    }
